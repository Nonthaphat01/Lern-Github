                            z.hp -= finalDmg; 
                            b.hitList.push(z.id); 
                            
                            if(isCrit) showDamage(z.x, z.y, "Cri " + Math.ceil(finalDmg), '#ff00ff');
                            else showDamage(z.x, z.y, Math.ceil(finalDmg), b.isMinion ? '#1e90ff' : (b.isOrb ? '#a200ff' : '#ffd700')); 
                            
                            if (z.hp > 0 && b.isOrb) {
                                let kbAngle = Math.atan2(z.y - b.y, z.x - b.x);
                                z.x += Math.cos(kbAngle) * 20; z.y += Math.sin(kbAngle) * 20;
                            }

                            for(let k=0; k<5; k++) particles.push({ x: z.x, y: z.y, vx: (Math.random()-0.5)*5, vy: (Math.random()-0.5)*5, life: 20, color: z.color });
                            if (b.pierce <= 0) { bullets.splice(j, 1); } else { b.pierce--; }

                            if (z.hp <= 0) { 
                                let mod = modeModifiers[currentMode];
                                let finalReward = z.reward;
                                if(currentMode === 'survival') finalReward *= (1 + Math.floor(currentSec / 60) * 0.10);
                                else finalReward += mod.bonusMoney;
                                finalReward *= playerStats.moneyMult; 
                                sessionToken += finalReward; pendingMoney += finalReward; updateTokenUI(); gainExp(z.exp); zombies.splice(i, 1); break; 
                            }
                        }
                    }
                }
                for (let i = particles.length - 1; i >= 0; i--) { let p = particles[i]; p.x += p.vx; p.y += p.vy; p.life--; if (p.life <= 0) particles.splice(i, 1); }
            }

            ctx.save(); ctx.scale(zoomScale, zoomScale);

            let scaledW = canvas.width / zoomScale; let scaledH = canvas.height / zoomScale;
            let camX = player.x - scaledW / 2; let camY = player.y - scaledH / 2; ctx.translate(-camX, -camY);

            ctx.fillStyle = '#111'; ctx.fillRect(0, 0, serverSettings.mapW, serverSettings.mapH);
            ctx.strokeStyle = '#222'; ctx.lineWidth = 1;
            for(let i=0; i<=serverSettings.mapW; i+=100) { ctx.beginPath(); ctx.moveTo(i,0); ctx.lineTo(i,serverSettings.mapH); ctx.stroke(); }
            for(let i=0; i<=serverSettings.mapH; i+=100) { ctx.beginPath(); ctx.moveTo(0,i); ctx.lineTo(serverSettings.mapW,i); ctx.stroke(); }
            ctx.strokeStyle = '#f00'; ctx.strokeRect(0, 0, serverSettings.mapW, serverSettings.mapH); 

            ctx.fillStyle = '#444'; ctx.strokeStyle = '#666'; ctx.lineWidth = 4;
            bunkers.forEach(b => { ctx.fillRect(b.x, b.y, b.w, b.h); ctx.strokeRect(b.x, b.y, b.w, b.h); });

            minions.forEach(m => {
                if (m.isDead) return;
                ctx.fillStyle = '#1e90ff'; ctx.beginPath(); ctx.arc(m.x, m.y, 12, 0, Math.PI*2); ctx.fill();
                ctx.fillStyle = '#fff'; ctx.fillRect(m.x - 5, m.y - 5, 4, 4); ctx.fillRect(m.x + 2, m.y - 5, 4, 4); 
                let barW = 24; let barH = 4; ctx.fillStyle = '#222'; ctx.fillRect(m.x - barW/2, m.y - 20, barW, barH); ctx.fillStyle = '#00ff88'; ctx.fillRect(m.x - barW/2, m.y - 20, barW * Math.max(0, m.hp/m.maxHp), barH);
            });

            // 🌟 วาดเพื่อนร่วมห้อง (ข้อมูลจาก Server จริงๆ) 🌟
            Object.values(otherPlayers).forEach(op => {
                ctx.fillStyle = '#a200ff'; ctx.beginPath(); ctx.arc(op.x, op.y, 15, 0, Math.PI * 2); ctx.fill();
                drawCosmetics(op.x, op.y, 15, op.equip || []); 
                ctx.fillStyle = '#fff'; ctx.font = 'bold 12px Kanit'; ctx.textAlign = 'center'; ctx.fillText(`${op.name} (Lv.${op.level})`, op.x, op.y - 25);
                let barW = 30; let barH = 4; ctx.fillStyle = '#222'; ctx.fillRect(op.x - barW/2, op.y - 20, barW, barH); ctx.fillStyle = '#00d2ff'; ctx.fillRect(op.x - barW/2, op.y - 20, barW * Math.max(0, op.hp/op.maxHp), barH);
            });

            ctx.fillStyle = '#ff00ff'; enemyBullets.forEach(eb => { ctx.beginPath(); ctx.arc(eb.x, eb.y, 5, 0, Math.PI * 2); ctx.fill(); });
            
            bullets.forEach(b => { 
                if (b.isMelee) {
                    ctx.save(); ctx.translate(b.x, b.y); ctx.rotate(b.angle);
                    let alpha = b.life / b.maxLife; let currentRadius = b.radius * (1.2 - alpha * 0.5); 
                    ctx.beginPath(); ctx.arc(0, 0, currentRadius, -Math.PI/2.5, Math.PI/2.5); ctx.lineWidth = 25 * alpha; ctx.strokeStyle = `rgba(0, 210, 255, ${alpha})`; ctx.lineCap = 'round'; ctx.stroke();
                    ctx.beginPath(); ctx.arc(0, 0, currentRadius * 0.85, -Math.PI/3, Math.PI/3); ctx.lineWidth = 10 * alpha; ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`; ctx.lineCap = 'round'; ctx.stroke();
                    ctx.restore();
                } else if (b.isOrb) { 
                    ctx.fillStyle = '#a200ff'; ctx.beginPath(); ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2); ctx.fill(); 
                } else if (b.isMinion) { 
                    ctx.fillStyle = '#1e90ff'; ctx.beginPath(); ctx.arc(b.x, b.y, b.radius || 4, 0, Math.PI * 2); ctx.fill(); 
                } else { 
                    ctx.fillStyle = '#ffd700'; ctx.beginPath(); ctx.arc(b.x, b.y, b.radius || 4, 0, Math.PI * 2); ctx.fill(); 
                }
            });

            zombies.forEach(z => {
                ctx.fillStyle = z.color; ctx.beginPath(); ctx.arc(z.x, z.y, z.radius, 0, Math.PI * 2); ctx.fill();
                
                if (z.onFireTime > 0) { z.onFireTime--; ctx.fillStyle = Math.random() > 0.5 ? '#ff4500' : '#ff8c00'; ctx.beginPath(); ctx.arc(z.x + (Math.random()*z.radius - z.radius/2), z.y - z.radius/2 + (Math.random()*10), z.radius*0.6, 0, Math.PI * 2); ctx.fill(); }

                if (z.isBigBoss) {
                    let barW = 120; let barH = 15; let bx = z.x - barW/2; let by = z.y - z.radius - 25;
                    ctx.fillStyle = '#222'; ctx.fillRect(bx, by, barW, barH); ctx.fillStyle = '#ff0000'; ctx.fillRect(bx, by, barW * Math.max(0, z.hp/z.maxHp), barH);
                    ctx.fillStyle = '#fff'; ctx.font = 'bold 16px Kanit'; ctx.textAlign = 'center'; ctx.fillText("💀 BOSS 💀 " + Math.ceil(z.hp), z.x, by - 5);
                } else if (z.isMiniBoss) {
                    let barW = 80; let barH = 10; let bx = z.x - barW/2; let by = z.y - z.radius - 20;
                    ctx.fillStyle = '#222'; ctx.fillRect(bx, by, barW, barH); ctx.fillStyle = '#ffcc00'; ctx.fillRect(bx, by, barW * Math.max(0, z.hp/z.maxHp), barH);
                    ctx.fillStyle = '#fff'; ctx.font = 'bold 14px Kanit'; ctx.textAlign = 'center'; ctx.fillText("MINI BOSS " + Math.ceil(z.hp), z.x, by - 5);
                } else {
                    let barW = z.radius * 2.5; let barH = 5; let bx = z.x - barW/2; let by = z.y - z.radius - 15;
                    ctx.fillStyle = '#222'; ctx.fillRect(bx, by, barW, barH); ctx.fillStyle = '#ff0055'; ctx.fillRect(bx, by, barW * Math.max(0, z.hp/z.maxHp), barH);
                    ctx.fillStyle = '#fff'; ctx.font = 'bold 12px Kanit'; ctx.textAlign = 'center'; ctx.fillText(Math.ceil(z.hp), z.x, by - 5);
                }
            });

            particles.forEach(p => { ctx.fillStyle = p.color; ctx.globalAlpha = p.life / 20; ctx.beginPath(); ctx.arc(p.x, p.y, 3, 0, Math.PI * 2); ctx.fill(); }); ctx.globalAlpha = 1.0;

            if (statLevels.aura > 0) { 
                let pulse = Math.sin(Date.now() / 150) * 10; let auraRad = 80 + (statLevels.aura * 15) + pulse;
                let grad = ctx.createRadialGradient(player.x, player.y, player.radius, player.x, player.y, auraRad); grad.addColorStop(0, 'rgba(255, 69, 0, 0.4)'); grad.addColorStop(0.8, 'rgba(255, 140, 0, 0.1)'); grad.addColorStop(1, 'rgba(255, 0, 0, 0)');
                ctx.fillStyle = grad; ctx.beginPath(); ctx.arc(player.x, player.y, auraRad, 0, Math.PI * 2); ctx.fill(); 
                ctx.strokeStyle = `rgba(255, 100, 0, ${0.4 + Math.sin(Date.now()/100)*0.4})`; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(player.x, player.y, auraRad, 0, Math.PI * 2); ctx.stroke();
            }

            let isHit = Date.now() - player.lastHitTime < 200;
            ctx.fillStyle = isHit ? '#ff0055' : '#00d2ff'; ctx.shadowBlur = 15; ctx.shadowColor = ctx.fillStyle; ctx.beginPath(); ctx.arc(player.x, player.y, player.radius, 0, Math.PI * 2); ctx.fill(); ctx.shadowBlur = 0;
            
            drawCosmetics(player.x, player.y, player.radius, myEquip); 
            
            if (currentWeapon === 'orb') {
                let wLvl = weaponLevels.orb; let numOrbs = Math.min(5, wLvl); let time = Date.now() / 500;
                for(let i=0; i<numOrbs; i++) {
                    let angle = time + (i * Math.PI * 2 / numOrbs); let ox = player.x + Math.cos(angle) * 35; let oy = player.y + Math.sin(angle) * 35;
                    ctx.fillStyle = '#a200ff'; ctx.beginPath(); ctx.arc(ox, oy, 6, 0, Math.PI*2); ctx.fill();
                    ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(ox-2, oy-2, 2, 0, Math.PI*2); ctx.fill();
                }
            }
            
            if (player.shield > 0) { ctx.strokeStyle = '#00ffff'; ctx.lineWidth = 3; ctx.beginPath(); ctx.arc(player.x, player.y, player.radius + 6, 0, Math.PI * 2); ctx.stroke(); ctx.fillStyle = '#00ffff'; ctx.font = 'bold 12px Kanit'; ctx.textAlign = 'center'; ctx.fillText(`🛡️${player.shield}`, player.x, player.y - 25); }

            let aimAngle = joyRight.active ? joyRight.angle : Math.atan2((mouse.y / zoomScale + camY) - player.y, (mouse.x / zoomScale + camX) - player.x);
            if (currentWeapon !== 'orb') { ctx.strokeStyle = '#fff'; ctx.lineWidth = 4; ctx.beginPath(); ctx.moveTo(player.x, player.y); ctx.lineTo(player.x + Math.cos(aimAngle)*25, player.y + Math.sin(aimAngle)*25); ctx.stroke(); }

            floatingTexts.forEach(ft => { ctx.fillStyle = ft.color; ctx.globalAlpha = ft.life / 30; ctx.font = 'bold 18px Kanit'; ctx.textAlign = 'center'; ctx.strokeStyle = '#000'; ctx.lineWidth = 2; ctx.strokeText(ft.text, ft.x, ft.y); ctx.fillText(ft.text, ft.x, ft.y); ft.y -= 1.5; ft.life--; }); floatingTexts = floatingTexts.filter(ft => ft.life > 0); ctx.globalAlpha = 1.0;

            ctx.restore(); 
        }
    </script>
</body>
</html>
