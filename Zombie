<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Zombie Defense Multiplayer</title>
    <!-- 🌟 โหลดไลบรารี Socket.io มาใช้งาน 🌟 -->
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Kanit:wght@300;500;700;900&display=swap');
        html, body { margin: 0; padding: 0; overflow: hidden; background-color: #111; font-family: 'Kanit', sans-serif; touch-action: none; user-select: none; width: 100vw; height: 100vh; position: fixed; top: 0; left: 0; }
        canvas { display: block; width: 100vw; height: 100vh; }
        #cMsg, .docs-gm { display: none !important; }

        #landscape-warning { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: #111; color: #fff; z-index: 99999; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
        @media screen and (orientation: portrait) { #landscape-warning { display: flex !important; } }

        #ui-layer { position: absolute; top: 10px; left: 10px; right: 10px; display: flex; justify-content: space-between; align-items: flex-start; z-index: 10; pointer-events: none; display: none; }
        .hud-box { background: rgba(0,0,0,0.8); border: 2px solid #444; border-radius: 10px; padding: 10px; pointer-events: auto; }
        .bar-container { width: 200px; height: 15px; background: #222; border-radius: 10px; overflow: hidden; margin-top: 5px; border: 1px solid #555; }
        #hp-fill { width: 100%; height: 100%; background: #ff0055; transition: 0.2s; }
        #exp-fill { width: 0%; height: 100%; background: #00d2ff; transition: 0.2s; }
        .wallet-box { background: rgba(0,0,0,0.8); border: 2px solid #ffd700; padding: 5px 15px; border-radius: 15px; color: #ffd700; font-weight: 900; font-size: 1.2rem; pointer-events: auto; text-align: right;}
        
        .btn-back { background: rgba(0,0,0,0.8); color: white; border: 1px solid #fff; border-radius: 10px; padding: 10px 15px; font-weight: bold; cursor: pointer; pointer-events: auto; font-family: 'Kanit'; transition: 0.2s;}
        .btn-back:hover { background: #fff; color: #000; }
        .btn-small { background: rgba(0,0,0,0.8); color: #fff; border: 1px solid #aaa; border-radius: 8px; padding: 5px 10px; font-weight: bold; cursor: pointer; pointer-events: auto; font-family: 'Kanit'; transition: 0.2s; }
        .btn-small:hover { background: #ffd700; color: #000; border-color: #ffd700; }

        .joystick-zone { position: absolute; bottom: 20px; width: 120px; height: 120px; background: rgba(255,255,255,0.1); border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; z-index: 20; display: none; touch-action: none; }
        .joystick-knob { position: absolute; top: 50%; left: 50%; width: 50px; height: 50px; background: rgba(255,255,255,0.5); border-radius: 50%; transform: translate(-50%, -50%); pointer-events: none; }
        #joy-left { left: 20px; } #joy-right { right: 20px; }
        
        #lobby-overlay, #upgrade-overlay, #loading-overlay, #gameover-overlay, #pause-overlay, #shop-overlay { display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 2000; flex-direction: column; align-items: center; justify-content: center; backdrop-filter: blur(5px); }
        #upgrade-overlay, #loading-overlay, #gameover-overlay, #pause-overlay, #shop-overlay { display: none; }
        
        #upgrade-options { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; justify-content: center; width: 95%; max-width: 900px; max-height: 70vh; overflow-y: auto; padding: 10px; }
        .upgrade-btn { border: 2px solid #ffd700; border-radius: 12px; padding: 15px 10px; color: white; font-size: 1.1rem; font-weight: bold; cursor: pointer; width: 140px; transition: 0.2s; font-family: 'Kanit'; text-align: center; box-shadow: 0 5px 10px rgba(0,0,0,0.5); }
        .upgrade-btn:hover { transform: scale(1.05); border-color: #00d2ff; }
        .upgrade-btn span { font-size: 0.75rem; color: #ddd; display: block; margin-top: 5px; }

        .shop-container { background: rgba(0,0,0,0.9); border: 2px solid #00d2ff; border-radius: 15px; padding: 20px; width: 90%; max-width: 800px; max-height: 80vh; overflow-y: auto; text-align: center; }
        .equip-slots { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
        .slot { width: 60px; height: 60px; border: 2px dashed #555; border-radius: 10px; background: #222; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: #00d2ff; }
        .shop-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; }
        .shop-item { background: #111; border: 1px solid #444; border-radius: 10px; padding: 10px; color: white; cursor: pointer; transition: 0.2s; }
        .shop-item:hover { border-color: #ffd700; }
        .shop-item.owned { border-color: #00ff88; }
        .shop-item.equipped { background: rgba(0,255,136,0.2); border-color: #00ff88; box-shadow: 0 0 10px rgba(0,255,136,0.5); }

        .hud-time { color:#fff; font-weight:bold; font-size:1.4rem; text-shadow: 0 0 5px #fff; }
        .hud-level { color:white; font-weight:bold; font-size:1.1rem; }
        .hud-info { font-size:0.9rem; margin-top:5px; font-weight:bold; }
        .room-badge { background:rgba(0,0,0,0.7); padding:5px 15px; border-radius:10px; color:#00ff88; font-weight:bold; font-size:0.9rem; border:1px solid #00ff88; }

        .lobby-title { font-size: 3rem; margin-bottom: 10px; color: #ff0055; text-shadow: 0 0 20px #ff0055; text-align: center; }
        .lobby-subtitle { font-size: 1.1rem; margin-bottom: 20px; color: #aaa; text-align: center; }
        .lobby-input { padding: 15px; font-size: 1.2rem; border-radius: 10px; border: 2px solid #444; background: #111; color: #fff; width: 80%; max-width: 300px; text-align: center; font-family: 'Kanit'; margin-bottom: 20px; }
        .lobby-btn { font-size: 1.2rem; padding: 10px 30px; margin: 5px; }

        @media (max-width: 800px), (max-height: 600px) {
            .lobby-title { font-size: 2rem; margin-bottom: 5px; }
            .lobby-subtitle { font-size: 0.9rem; margin-bottom: 10px; }
            .lobby-input { padding: 10px; font-size: 1rem; margin-bottom: 10px; width: 90%; }
            .lobby-btn { font-size: 1rem; padding: 8px 15px; margin: 3px; }
            #lobby-overlay > div { margin-bottom: 10px !important; }

            #ui-layer { top: 5px; left: 5px; right: 5px; }
            .hud-box { padding: 5px; border-radius: 5px; }
            .hud-time { font-size: 1rem; }
            .hud-level { font-size: 0.9rem; }
            .hud-info { font-size: 0.75rem; margin-top: 2px; }
            .bar-container { width: 120px; height: 8px; margin-top: 2px; }
            .room-badge { padding: 3px 8px; font-size: 0.75rem; border-radius: 5px; }
            .wallet-box { padding: 3px 10px; font-size: 1rem; border-radius: 8px; }
            .btn-small { padding: 3px 8px; font-size: 0.75rem; }
            .joystick-zone { width: 90px; height: 90px; bottom: 30px; }
            .joystick-knob { width: 40px; height: 40px; }
            #joy-left { left: 15px; } #joy-right { right: 15px; }
            #upgrade-options { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; padding: 0; }
            .upgrade-btn { width: 100%; padding: 8px 2px; font-size: 0.8rem; border-radius: 8px; }
            .upgrade-btn span { font-size: 0.6rem; margin-top: 2px;}
            #upgrade-title { font-size: 1.5rem; } #upgrade-desc { font-size: 0.9rem; }
        }
    </style>
</head>
<body>

    <div id="landscape-warning">
        <h1 style="font-size:4rem;">📱🔄</h1><h2>กรุณาหมุนโทรศัพท์เป็นแนวนอน</h2><p>เพื่อการแสดงผลและบังคับเกมที่ดีที่สุดครับ!</p>
    </div>

    <div id="lobby-overlay">
        <h1 class="lobby-title">🧟 ZOMBIE CO-OP 🔫</h1>
        <p class="lobby-subtitle">ตั้งชื่อห้องให้ตรงกันเพื่อเล่นกับเพื่อน</p>
        <input type="text" id="room-input" class="lobby-input" placeholder="ใส่ชื่อห้อง (เว้นว่าง = เล่นคนเดียว)" maxlength="15">
        
        <div style="margin-bottom: 15px; width:100%; max-width:500px;">
            <p style="color:#fff; font-weight:bold; text-align:center; font-size:1rem; margin-bottom:10px;">เลือกระดับความยาก</p>
            <div style="display:flex; gap: 5px; justify-content:center; flex-wrap:wrap;">
                <button class="btn-back lobby-btn" style="background:linear-gradient(to right, #28a745, #218838); border-color:#fff;" onclick="joinRoom('survival')">🟢 SURVIVAL</button>
                <button class="btn-back lobby-btn" style="background:linear-gradient(to right, #ffc107, #d39e00); color:#000; border-color:#fff;" onclick="joinRoom('hard')">🟡 HARD</button>
                <button class="btn-back lobby-btn" style="background:linear-gradient(to right, #dc3545, #c82333); border-color:#fff;" onclick="joinRoom('god')">🔴 GOD</button>
            </div>
        </div>
        
        <button class="btn-back lobby-btn" style="background:linear-gradient(to right, #ff8c00, #ff4e50); border:none; margin-bottom:15px;" onclick="openShop()">🛒 ร้านค้าเตรียมพร้อม</button>
        <button class="btn-back lobby-btn" style="border-color:#555;" onclick="goBackToMain()">🏠 กลับหน้าหลัก</button>
    </div>

    <div id="shop-overlay">
        <div class="shop-container">
            <h1 style="color:#ffd700; margin-top:0;">🛒 ตลาดมืดก่อนลงสนาม</h1>
            <div style="color:#00ff88; font-size:1.2rem; margin-bottom:10px;">เงินของคุณ: <span id="shop-token">0</span> 💰</div>
            <h3 style="color:#fff;">สล็อตที่ใส่แล้ว (<span id="slot-count">0</span>/4)</h3>
            <div class="equip-slots" id="equip-slots-container"></div>
            <h3 style="color:#fff; text-align:left; border-bottom:1px solid #444;">🔥 บัฟพิเศษ</h3>
            <div class="shop-grid" id="shop-buffs"></div>
            <h3 style="color:#fff; text-align:left; border-bottom:1px solid #444; margin-top:20px;">👗 ของตกแต่ง</h3>
            <div class="shop-grid" id="shop-cosmetics"></div>
            <button class="btn-back" style="margin-top:25px; padding:15px 40px; background:#222; border-color:#fff;" onclick="closeShop()">✅ เสร็จสิ้น / ปิดร้าน</button>
        </div>
    </div>

    <div id="loading-overlay"><h2 style="color:#00d2ff; text-align:center; padding: 20px;">กำลังโหลดแผนที่...<br><br><span id="loading-text" style="font-size:1rem; color:#aaa;">กำลังเตรียมทรัพยากร</span></h2></div>

    <div id="ui-layer">
        <div style="display:flex; flex-direction:column; gap:10px;">
            <div class="hud-box">
                <div class="hud-time">⏱️ รอดชีวิต: <span id="timer-text" style="color:#00ff88;">00:00</span></div><hr style="border: 1px solid #333; margin: 5px 0;">
                <div class="hud-level">LEVEL: <span id="level-text" style="color:#ffd700;">1</span></div>
                <div class="hud-info" style="color:#ffd700;">อาวุธ: <span id="weapon-text" style="color:#fff;">Pistol (Lv.1)</span></div>
                <div class="hud-info" style="color:#ff0055;">HP: <span id="hp-text">100</span></div>
                <div class="bar-container"><div id="hp-fill"></div></div>
                <div class="hud-info" style="color:#00d2ff;">EXP</div>
                <div class="bar-container"><div id="exp-fill"></div></div>
            </div>
            <div id="minion-status-container" style="display:flex; flex-direction:column; gap:5px; pointer-events:none;"></div>
        </div>
        <div style="display:flex; flex-direction:column; gap:10px; align-items:flex-end;">
            <div style="display:flex; gap: 8px;">
                <button class="btn-small" onclick="toggleFullScreen()">🔲 เต็มจอ</button><button class="btn-small" onclick="togglePause()">⏸️ พัก</button><button class="btn-small" style="background: rgba(150,0,0,0.8); border-color:#ff4e50;" onclick="goBackToMain()">🚪 ออก</button>
            </div>
            <div class="room-badge">🌍 <span id="room-display"></span> <span id="mode-display" style="color:yellow; margin-left:5px;"></span></div><div class="wallet-box">💰 <span id="player-token">0</span></div>
        </div>
    </div>

    <div id="joy-left" class="joystick-zone"><div class="joystick-knob" id="knob-left"></div></div>
    <div id="joy-right" class="joystick-zone"><div class="joystick-knob" id="knob-right"></div></div>

    <div id="pause-overlay" style="z-index: 2500;">
        <h1 style="color:#00d2ff; font-size:4rem; margin:0; text-shadow: 0 0 20px #000;">GAME PAUSED</h1><p style="color:#aaa; font-size:1.5rem;">พักดื่มน้ำแป๊บนึง...</p>
        <div style="display:flex; gap: 15px; margin-top: 20px; flex-wrap: wrap; justify-content: center;">
            <button class="btn-back" style="font-size:1.2rem; padding:15px 30px; background:linear-gradient(to right, #00ff88, #009955); border-color:#00ff88;" onclick="togglePause()">▶️ เล่นต่อ</button>
            <button class="btn-back" style="font-size:1.2rem; padding:15px 30px;" onclick="goBackToMain()">🏠 ออกไปหน้าแรก</button>
        </div>
    </div>

    <div id="upgrade-overlay">
        <h1 id="upgrade-title" style="color:#ffd700; text-shadow: 0 0 20px #ff8c00; margin-bottom: 5px; font-size:2.5rem;">🌟 LEVEL UP! 🌟</h1>
        <h3 id="upgrade-desc" style="color:#fff; margin-top:0;">เลือกความสามารถใหม่</h3><div id="upgrade-options"></div>
    </div>

    <div id="gameover-overlay">
        <h1 style="color:white; font-size:4rem; margin:0; text-shadow: 0 0 20px #000;">YOU DIED</h1>
        <p style="color:#ffd700; font-size:1.5rem;">รอดชีวิตไปได้ถึงเลเวล <span id="final-level"></span> (เวลา <span id="final-time"></span>)</p>
        <div style="display:flex; gap: 15px; margin-top: 20px; flex-wrap: wrap; justify-content: center;">
            <button class="btn-back" style="font-size:1.2rem; padding:15px 30px; background:linear-gradient(to right, #00d2ff, #0066cc); border-color:#00d2ff;" onclick="softRestart()">🔄 เล่นอีกครั้ง</button>
            <button class="btn-back" style="font-size:1.2rem; padding:15px 30px;" onclick="goBackToMain()">🏠 กลับหน้าเริ่มต้น</button>
        </div>
    </div>

    <canvas id="gameCanvas"></canvas>

    <script>
        // 🌟 แทนที่ URL ด้วยเซิร์ฟเวอร์ Render ของคุณ 🌟
        const SERVER_URL = 'https://lenggay.onrender.com'; // <--- เปลี่ยน URL ตรงนี้ถ้าเปลี่ยนชื่อเซิร์ฟเวอร์
        
        let socket; // ตัวแปรสำหรับ Socket.io

        const canvas = document.getElementById('gameCanvas'); const ctx = canvas.getContext('2d');
        function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; } window.addEventListener('resize', resize); resize();

        let sessionUser = 'Guest' + Math.floor(Math.random()*1000); let sessionToken = 0; let pendingMoney = 0; let lastMoneySave = Date.now();
        let scriptUrl = ''; let myRoom = 'GLOBAL'; let currentMode = 'survival'; let otherPlayers = {}; let manualPause = false; 
        
        const modeModifiers = {
            survival: { name: "[SURVIVAL]", hp: 1.0, dmg: 1.0, exp: 1.0, bonusMoney: 0 },
            hard: { name: "[HARD]", hp: 2.25, dmg: 1.35, exp: 1.5, bonusMoney: 1 },
            god: { name: "[GOD]", hp: 3.25, dmg: 1.60, exp: 2.5, bonusMoney: 2 }
        };

        let serverSettings = { 
            expMult: 1.0, spawnMs: 1500, spawnAmt: 1, mapW: 3000, mapH: 3000, bunkerAmt: 15,
            maxLevel: 100, expScaleBase: 1.15, expScaleFlat: 100, 
            z1: { hp: 30, speed: 1.5, damage: 15, reward: 5, exp: 10, radius: 15, color: '#00ff88' },
            z2: { hp: 15, speed: 3.5, damage: 10, reward: 10, exp: 15, radius: 12, color: '#ff8c00' },
            z3: { hp: 150, speed: 0.8, damage: 35, reward: 30, exp: 200, radius: 25, color: '#aa00ff' }, 
            z4: { hp: 40, speed: 1.2, damage: 20, reward: 15, exp: 30, radius: 14, color: '#00ffff', isRanged: true } 
        };

        const shopItems = [
            { id: 'buff_weapon', name: "เลือกปืนเวล 1", icon: "🔫", price: 5000, type: "buff" },
            { id: 'buff_money', name: "เงินคูณ x2", icon: "💸", price: 10000, type: "buff" },
            { id: 'buff_hp', name: "เลือด +100", icon: "❤️", price: 5000, type: "buff" },
            { id: 'cos_helm', name: "หมวกทหาร", icon: "🪖", price: 2000, type: "cosmetic" },
            { id: 'cos_glass', name: "แว่นตาดำ", icon: "🕶️", price: 2000, type: "cosmetic" },
            { id: 'cos_wings', name: "ปีกนางฟ้า", icon: "👼", price: 20000, type: "cosmetic" },
            { id: 'cos_aura', name: "ออร่าไฟ", icon: "🔥", price: 30000, type: "cosmetic" }
        ];
        let myInventory = JSON.parse(localStorage.getItem('zInv')) || {}; let myEquip = JSON.parse(localStorage.getItem('zEquip')) || [];
        let activeTimeMs = 0; let lastFrameTime = Date.now(); let nextMiniBossSec = 60; let nextBigBossSec = 300; 

        if ('ontouchstart' in window || navigator.maxTouchPoints > 0) { document.getElementById('joy-left').style.display = 'block'; document.getElementById('joy-right').style.display = 'block'; }

        let bunkers = []; let isGameOver = false; let isGamePaused = true; 
        
        let weapons = {
            pistol: { name: "Pistol", baseBullets: 1, spread: 0, cooldown: 300, damageMult: 1.0, pierce: 0 },
            shotgun: { name: "Shotgun", baseBullets: 3, spread: 0.6, cooldown: 600, damageMult: 0.6, pierce: 0 },
            machinegun: { name: "SMG", baseBullets: 1, spread: 0.2, cooldown: 100, damageMult: 0.45, pierce: 0 },
            sniper: { name: "Sniper", baseBullets: 1, spread: 0, cooldown: 1000, damageMult: 3.5, pierce: 2 },
            twin: { name: "Twin Gun", baseBullets: 2, spread: 0.1, cooldown: 250, damageMult: 0.8, pierce: 0 },
            sword: { name: "Katana", baseBullets: 1, spread: 0, cooldown: 600, damageMult: 1.0, pierce: 999 },
            orb: { name: "Magic Orb", baseBullets: 1, spread: 0, cooldown: 400, damageMult: 1.60, pierce: 0 } 
        };
        let currentWeapon = 'pistol';
        let weaponLevels = { pistol: 1, shotgun: 0, machinegun: 0, sniper: 0, twin: 0, sword: 0, orb: 0 };

        let statLevels = { speed: 1, damage: 1, maxhp: 1, firerate: 1, armor: 0, shield: 0, aura: 0, minion: 0, crit: 0, regen: 0 }; 
        let playerStats = { speed: 4, damageMult: 1.0, maxHp: 100, fireRateMult: 1.0, moneyMult: 1.0 };
        let player = { x: 0, y: 0, radius: 15, hp: 100, exp: 0, maxExp: 100, level: 1, lastHitTime: 0, lastHealTime: 0, lastShotTime: 0, shield: 0, lastShieldRecharge: 0, lastAuraTick: 0, lastOrbShot: 0, orbIndex: 0 };
        
        let bullets = []; let enemyBullets = []; let zombies = []; let particles = []; let floatingTexts = []; let minions = []; 

        let keys = { w: false, a: false, s: false, d: false }; let mouse = { x: 0, y: 0, isDown: false };
        let joyLeft = { active: false, dx: 0, dy: 0 }; let joyRight = { active: false, dx: 0, dy: 0, angle: 0 };

        window.addEventListener('keydown', e => { if(e.key==='w'||e.key==='W') keys.w=true; if(e.key==='a'||e.key==='A') keys.a=true; if(e.key==='s'||e.key==='S') keys.s=true; if(e.key==='d'||e.key==='D') keys.d=true; });
        window.addEventListener('keyup', e => { if(e.key==='w'||e.key==='W') keys.w=false; if(e.key==='a'||e.key==='A') keys.a=false; if(e.key==='s'||e.key==='S') keys.s=false; if(e.key==='d'||e.key==='D') keys.d=false; });
        window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
        window.addEventListener('mousedown', () => mouse.isDown = true); window.addEventListener('mouseup', () => mouse.isDown = false);

        function setupJoystick(zoneId, knobId, joyData, isAim) {
            const zone = document.getElementById(zoneId); const knob = document.getElementById(knobId); let cx, cy, maxR = 40; let currentTouchId = null;
            function updateJoy(touch) {
                let rect = zone.getBoundingClientRect(); cx = rect.left + rect.width/2; cy = rect.top + rect.height/2; 
                let dx = touch.clientX - cx; let dy = touch.clientY - cy; let dist = Math.hypot(dx, dy);
                if (dist > maxR) { dx = (dx/dist)*maxR; dy = (dy/dist)*maxR; }
                knob.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`; joyData.dx = dx / maxR; joyData.dy = dy / maxR; if(isAim) joyData.angle = Math.atan2(dy, dx);
            }
            zone.addEventListener('touchstart', e => { e.preventDefault(); for(let i = 0; i < e.changedTouches.length; i++) { if(currentTouchId === null) { currentTouchId = e.changedTouches[i].identifier; joyData.active = true; updateJoy(e.changedTouches[i]); break; } } }, {passive: false});
            zone.addEventListener('touchmove', e => { e.preventDefault(); for(let i = 0; i < e.changedTouches.length; i++) { if(e.changedTouches[i].identifier === currentTouchId) updateJoy(e.changedTouches[i]); } }, {passive: false});
            function handleEnd(e) { e.preventDefault(); for(let i = 0; i < e.changedTouches.length; i++) { if(e.changedTouches[i].identifier === currentTouchId) { currentTouchId = null; joyData.active = false; joyData.dx = 0; joyData.dy = 0; knob.style.transform = `translate(-50%, -50%)`; } } }
